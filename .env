# Postgres
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Redsi
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ============================================================================
# MLflow Configuration
# ============================================================================
# Service Consumer:
#   - MLflow server
#   - FastAPI inference service
#   - training/train.py
#
# Purpose:
#   MLflow tracks experiments and stores registered models.
# ============================================================================

# MLflow tracking server URL
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# PostgreSQL backend store URI
MLFLOW_BACKEND_STORE_URI=postgresql://modelserve:change_me@postgres:5432/mlflow

# Artifact storage location
# Local path in development, S3 in production
MLFLOW_ARTIFACT_ROOT=./mlruns

# Registered model name
MODEL_NAME=modelserve-model

# Model stage loaded by FastAPI
MODEL_STAGE=Production